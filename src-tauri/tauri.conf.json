{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Logr",
  "version": "0.2.4",
  "identifier": "co.glus.tail-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Logr — 개발자를 위한 로그 뷰어",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "개발자를 위한 실시간 로그 뷰어",
    "longDescription": "개발자의, 개발자에 의한, 개발자를 위한 로그 뷰어. Unix tail -f를 대체하는 실시간 로그 모니터링 도구. 멀티탭, 검색, 필터, 하이라이트, SSH 원격 파일 지원.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": "ko-KR"
      }
    }
  }
}
